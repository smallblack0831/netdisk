{"ast":null,"code":"export default {\n  name: \"ShareComponent\",\n  props: {\n    typeList: null\n  },\n  data() {\n    return {\n      tableData: [],\n      ids: []\n    };\n  },\n  created() {\n    this.load();\n  },\n  methods: {\n    copy(row) {\n      let currentUrl = location.href.substring(0, location.href.indexOf('/front'));\n      let shareLink = currentUrl + '/front/openShare?code=' + row.code + '&shareId=' + row.id;\n      let _input = document.createElement(\"input\"); // 直接构建input\n      _input.value = shareLink; // 设置内容\n      document.body.appendChild(_input); // 添加临时实例\n      _input.select(); // 选择实例内容\n      document.execCommand(\"Copy\"); // 执行复制\n      document.body.removeChild(_input);\n      this.$message.success(\"复制成功\");\n    },\n    del(id) {\n      // 单个删除\n      this.$confirm('您确定取消分享吗？', '确认取消分享', {\n        type: \"warning\"\n      }).then(response => {\n        this.$request.delete('/share/delete/' + id).then(res => {\n          // 这里传的是 trash的id  要传file_id\n          if (res.code === '200') {\n            // 表示操作成功\n            this.$message.success('操作成功');\n            this.load();\n          } else {\n            this.$message.error(res.msg); // 弹出错误的信息\n          }\n        });\n      }).catch(() => {});\n    },\n    handleSelectionChange(rows) {\n      // 当前选中的所有的行数据\n      this.ids = rows.map(v => v.id); //  [1,2]\n    },\n\n    delBatch() {\n      // 批量删除\n      if (!this.ids.length) {\n        this.$message.warning('请选择数据');\n        return;\n      }\n      this.$confirm('您确定批量取消分享吗？', '确认取消分享', {\n        type: \"warning\"\n      }).then(response => {\n        this.$request.delete('/share/delete/batch', {\n          data: this.ids\n        }).then(res => {\n          if (res.code === '200') {\n            // 表示操作成功\n            this.$message.success('操作成功');\n            this.load();\n          } else {\n            this.$message.error(res.msg); // 弹出错误的信息\n          }\n        });\n      }).catch(() => {});\n    },\n    load() {\n      this.$request.get('/share/selectAll').then(res => {\n        this.tableData = res.data || [];\n      });\n    },\n    mouseEnter(row) {\n      this.$set(row, 'optShow', true);\n    },\n    mouseLeave(row) {\n      this.$set(row, 'optShow', false);\n    }\n  }\n};","map":{"version":3,"names":["name","props","typeList","data","tableData","ids","created","load","methods","copy","row","currentUrl","location","href","substring","indexOf","shareLink","code","id","_input","document","createElement","value","body","appendChild","select","execCommand","removeChild","$message","success","del","$confirm","type","then","response","$request","delete","res","error","msg","catch","handleSelectionChange","rows","map","v","delBatch","length","warning","get","mouseEnter","$set","mouseLeave"],"sources":["src/components/Share.vue"],"sourcesContent":["<template>\n  <div>\n    <div style=\"padding: 15px; border-bottom: 1px solid #ddd\">\n      <el-button type=\"danger\" plain @click=\"delBatch\" :disabled=\"!tableData.length || !ids.length\">取消分享</el-button>\n    </div>\n    <el-table size=\"medium\" :data=\"tableData\" stripe @selection-change=\"handleSelectionChange\">\n      <el-table-column type=\"selection\" width=\"55\" align=\"center\"></el-table-column>\n      <el-table-column label=\"文件名称\">\n        <template v-slot=\"scope\">\n          <div style=\"display: flex; cursor: pointer\"  @mouseenter=\"mouseEnter(scope.row)\" @mouseleave=\"mouseLeave(scope.row)\">\n            <div style=\"flex: 1\">\n              <i style=\"color: #409EFF\" :class=\"typeList.find(v => v.text === scope.row.type)?.icon || 'el-icon-file'\"></i>\n              <span v-if=\"!scope.row.unSave\" style=\"margin-left: 5px\">{{ scope.row.name }}</span>\n            </div>\n            <div style=\"color: #409EFF; font-size: 14px\" v-if=\"scope.row.optShow\">\n              <el-tooltip content=\"取消分享\" effect=\"light\" :open-delay=\"1000\">\n                <i class=\"el-icon-remove-outline\" style=\"margin-right: 10px; cursor: pointer\" @click=\"del(scope.row.id)\"></i>\n              </el-tooltip>\n              <el-tooltip content=\"复制链接\" effect=\"light\" :open-delay=\"1000\">\n                <i class=\"el-icon-document-copy\" style=\"margin-right: 10px; cursor: pointer\" @click=\"copy(scope.row)\"></i>\n              </el-tooltip>\n            </div>\n          </div>\n        </template>\n      </el-table-column>\n      <el-table-column prop=\"shareTime\" label=\"分享时间\" width=\"200\"></el-table-column>\n      <el-table-column prop=\"status\" label=\"状态\" width=\"200\">\n        <template v-slot=\"scope\">\n          <span style=\"color: red\" v-if=\"scope.row.status.includes('小时')\">{{ scope.row.status }}</span>\n          <span v-else>{{ scope.row.status }}</span>\n        </template>\n      </el-table-column>\n      <el-table-column prop=\"count\" label=\"访问次数\" width=\"200\"></el-table-column>\n    </el-table>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"ShareComponent\",\n  props: {\n    typeList: null\n  },\n  data() {\n    return {\n      tableData: [],\n      ids: []\n    }\n  },\n  created() {\n    this.load()\n  },\n  methods: {\n    copy(row) {\n      let currentUrl = location.href.substring(0, location.href.indexOf('/front'))\n      let shareLink = currentUrl + '/front/openShare?code=' + row.code + '&shareId=' + row.id\n\n      let _input = document.createElement(\"input\");   // 直接构建input\n      _input.value = shareLink;  // 设置内容\n      document.body.appendChild(_input);    // 添加临时实例\n      _input.select();   // 选择实例内容\n      document.execCommand(\"Copy\");   // 执行复制\n      document.body.removeChild(_input)\n      this.$message.success(\"复制成功\")\n    },\n    del(id) {   // 单个删除\n      this.$confirm('您确定取消分享吗？', '确认取消分享', {type: \"warning\"}).then(response => {\n        this.$request.delete('/share/delete/' + id).then(res => {  // 这里传的是 trash的id  要传file_id\n          if (res.code === '200') {   // 表示操作成功\n            this.$message.success('操作成功')\n            this.load()\n          } else {\n            this.$message.error(res.msg)  // 弹出错误的信息\n          }\n        })\n      }).catch(() => {\n      })\n    },\n    handleSelectionChange(rows) {   // 当前选中的所有的行数据\n      this.ids = rows.map(v => v.id)   //  [1,2]\n    },\n    delBatch() {   // 批量删除\n      if (!this.ids.length) {\n        this.$message.warning('请选择数据')\n        return\n      }\n      this.$confirm('您确定批量取消分享吗？', '确认取消分享', {type: \"warning\"}).then(response => {\n        this.$request.delete('/share/delete/batch', {data: this.ids}).then(res => {\n          if (res.code === '200') {   // 表示操作成功\n            this.$message.success('操作成功')\n            this.load()\n          } else {\n            this.$message.error(res.msg)  // 弹出错误的信息\n          }\n        })\n      }).catch(() => {\n      })\n    },\n    load() {\n      this.$request.get('/share/selectAll').then(res => {\n        this.tableData = res.data || []\n      })\n    },\n    mouseEnter(row) {\n      this.$set(row, 'optShow', true)\n    },\n    mouseLeave(row) {\n      this.$set(row, 'optShow', false)\n    }\n  }\n}\n</script>\n\n<style scoped>\n\n</style>"],"mappings":"AAsCA;EACAA,IAAA;EACAC,KAAA;IACAC,QAAA;EACA;EACAC,KAAA;IACA;MACAC,SAAA;MACAC,GAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,IAAA;EACA;EACAC,OAAA;IACAC,KAAAC,GAAA;MACA,IAAAC,UAAA,GAAAC,QAAA,CAAAC,IAAA,CAAAC,SAAA,IAAAF,QAAA,CAAAC,IAAA,CAAAE,OAAA;MACA,IAAAC,SAAA,GAAAL,UAAA,8BAAAD,GAAA,CAAAO,IAAA,iBAAAP,GAAA,CAAAQ,EAAA;MAEA,IAAAC,MAAA,GAAAC,QAAA,CAAAC,aAAA;MACAF,MAAA,CAAAG,KAAA,GAAAN,SAAA;MACAI,QAAA,CAAAG,IAAA,CAAAC,WAAA,CAAAL,MAAA;MACAA,MAAA,CAAAM,MAAA;MACAL,QAAA,CAAAM,WAAA;MACAN,QAAA,CAAAG,IAAA,CAAAI,WAAA,CAAAR,MAAA;MACA,KAAAS,QAAA,CAAAC,OAAA;IACA;IACAC,IAAAZ,EAAA;MAAA;MACA,KAAAa,QAAA;QAAAC,IAAA;MAAA,GAAAC,IAAA,CAAAC,QAAA;QACA,KAAAC,QAAA,CAAAC,MAAA,oBAAAlB,EAAA,EAAAe,IAAA,CAAAI,GAAA;UAAA;UACA,IAAAA,GAAA,CAAApB,IAAA;YAAA;YACA,KAAAW,QAAA,CAAAC,OAAA;YACA,KAAAtB,IAAA;UACA;YACA,KAAAqB,QAAA,CAAAU,KAAA,CAAAD,GAAA,CAA